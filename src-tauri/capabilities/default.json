{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for NeoSwarm",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "spawn-python",
          "cmd": "bash",
          "args": [
            "-c",
            { "validator": ".*" }
          ],
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-python",
          "cmd": "bash",
          "args": [
            "-c",
            { "validator": ".*" }
          ],
          "sidecar": false
        }
      ]
    },
    "notification:default",
    "opener:default"
  ]
}
