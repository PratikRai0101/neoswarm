{
  "productName": "NeoSwarm",
  "version": "0.1.0",
  "identifier": "com.neoswarm.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../frontend && npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "NeoSwarm",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "resources": {
      "../backend": "backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/512x512.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}